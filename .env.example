# ─────────────────────────────────────────────────────────────
# Clarity.ai — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────

# ── AI (Groq) ─────────────────────────────────────────────────
# Free API key — https://console.groq.com (no credit card required)
GROQ_API_KEY=gsk_...

# ── Auth (Clerk) ───────────────────────────────────────────────
# Create a project at https://clerk.com
# Enable "Email" and "Google" sign-in methods in the Clerk dashboard
# Add your production domain under Clerk → Domains
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Database (Supabase) ────────────────────────────────────────
# Create a project at https://supabase.com
# Run the SQL schema below in Supabase → SQL Editor before first use
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────────────────────
# Supabase schema — run once in SQL Editor
# ─────────────────────────────────────────────────────────────
#
#   create table public.analyses (
#     id         uuid        primary key default gen_random_uuid(),
#     user_id    text        not null,
#     file_name  text        not null,
#     summary    text        not null,
#     key_points jsonb       not null,
#     risks      jsonb       not null,
#     actions    jsonb       not null,
#     created_at timestamptz not null default now()
#   );
#
#   create index analyses_user_id_idx on public.analyses(user_id);
#
# ─────────────────────────────────────────────────────────────
